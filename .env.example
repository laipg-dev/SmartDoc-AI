# ==============================================================================
# 1. BỘ CHUYỂN MẠCH TRUNG TÂM (PROVIDERS)
# Đổi giá trị ở đây để chuyển đổi toàn bộ hệ thống giữa Cloud và Local
# ==============================================================================
# Lựa chọn LLM: gemini | ollama 
LLM_PROVIDER=gemini

# Lựa chọn Embedding: google | huggingface
EMBEDDING_PROVIDER=google

# ==============================================================================
# 2. KHÓA BẢO MẬT (API KEYS)
# ==============================================================================
GOOGLE_API_KEY=
GEMINI_MODEL=models/gemini-2.5-flash

# ==============================================================================
# 3. CẤU HÌNH LOCAL LLM (OLLAMA)
# Chỉ có tác dụng khi LLM_PROVIDER=ollama
# ==============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# ==============================================================================
# 4. CẤU HÌNH EMBEDDING MODELS
# ==============================================================================
# Dùng cho giảng viên (Khi EMBEDDING_PROVIDER=huggingface)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DEVICE=cpu

# Dùng cho local nhẹ (Khi EMBEDDING_PROVIDER=ollama)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ==============================================================================
# 5. CẤU HÌNH RAG PIPELINE (XỬ LÝ DỮ LIỆU)
# ==============================================================================
# Cấu hình cắt tài liệu (Chunker)
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# Số lượng tài liệu liên quan trả về từ Vector DB
RETRIEVER_K=3